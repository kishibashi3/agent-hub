# agent-hub サーバー側の環境変数テンプレ
#
# 使い方:
#   cd backend
#   cp .env.example .env
#   # .env を自分の値で書き換える
#   npm run mcp:start    # dotenv が自動で .env を読む

# ===========================================================
# 認証モード
# ===========================================================
#
# trust : X-User-Id ヘッダーをそのまま信頼。localhost 互換、インターネット公開禁止
# pat   : Authorization: Bearer <github-pat> を GitHub API で検証して userId 解決
#
# インターネット公開（Fly.io 等）する場合は必ず pat（または将来の oauth）

AUTH_MODE=trust

# ===========================================================
# pat モードで Org 制限する場合（任意）
# ===========================================================
# 指定すると、その GitHub Org に所属するユーザーのみアクセス可能になる
# 必要 PAT scope: read:org

# AGENT_HUB_GITHUB_ORG=your-org-name

# ===========================================================
# サーバー設定
# ===========================================================

MCP_PORT=3000
DB_PATH=./data/app.db
